# ─── Slack ───────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...        # Install App page
SLACK_APP_TOKEN=xapp-...        # Socket Mode app-level token (connections:write)
CURIE_USER_TOKEN=xoxp-...       # your user token (RTS without action_token; Trigger C)
CURIE_CHANNEL_ID=C...           # #experiments (set after creation)
CURIE_LIST_ID=                  # set by setup routine
CURIE_MODE=full                 # full | preflight_only
# SEED authorship = bot-personas (decided Jul 10) → no per-user tokens needed.
# For persona display names, app needs chat:write.customize scope (else seed uses "*Name:* " prefix).
CURIE_GENERAL_ID=C0BGCMQGXL2   # #general (optional; general-channel flavor)
# ─── LLM (OpenAI is the default; Anthropic optional fallback) ───
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1            # version-locked; swap in one place
# ANTHROPIC_API_KEY=sk-ant-...  # optional fallback
